rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow reading the connection test document
    match /test/connection {
      allow read: if true;
    }
    
    // Ensure users can only read and write their own data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Apply the same rule to all subcollections (customers, transactions, reminders, etc.)
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
